{
  "data": {
    "batch_size": 32,
    "input_size": 224,
    "num_classes": 2,
    "num_workers": 4
  },
  "evaluation": {
    "metrics": [
      "accuracy",
      "precision",
      "recall",
      "f1"
    ],
    "output_dir": "./results",
    "save_predictions": true
  },
  "experiment_name": "mirabest_diffusion_v1",
  "model": {
    "backbone": "resnet50",
    "checkpoint_dir": "./checkpoints",
    "dropout": 0.2,
    "embedding_dim": 256,
    "num_layers": 18,
    "pretrained": true,
    "type": "classification"
  },
  "optimization": {
    "max_trials": 25,
    "method": "bayesian",
    "parameters": {
      "dropout": {
        "max": 0.5,
        "min": 0.1
      },
      "learning_rate": {
        "log": true,
        "max": 0.01,
        "min": 0.0001
      },
      "weight_decay": {
        "max": 0.1,
        "min": 1e-05
      }
    }
  },
  "seed": 42,
  "training": {
    "early_stopping": {
      "delta": 0.001,
      "patience": 10
    },
    "epochs": 50,
    "learning_rate": 0.0005,
    "log_interval": 10,
    "optimizer": "adamw",
    "save_best_only": true,
    "scheduler": {
      "type": "cosine",
      "warmup_epochs": 5
    },
    "weight_decay": 0.01
  }
}